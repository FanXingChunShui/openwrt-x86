CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_generic=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# LuCI
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-firewall=y

# QoS
CONFIG_PACKAGE_qos-scripts=y
CONFIG_PACKAGE_luci-app-qos=y

# VPN
CONFIG_PACKAGE_luci-app-vpn=y
CONFIG_PACKAGE_openvpn=y
CONFIG_PACKAGE_ipsec-tools=y

# helloworld
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-ssr-plus=y

# Network
CONFIG_DEFAULT_network=y
CONFIG_PACKAGE_luci-app-uhttpd=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y

# Filesystem
CONFIG_TARGET_ROOTFS_PARTSIZE=750
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_EXT4_MAX_USIZE=100

# Build settings
CONFIG_PARALLEL_MAKE=y
CONFIG_CCACHE=y
CONFIG_DOWNLOAD_FOLDER="$PWD/download"
CONFIG_BUILD_LOG=y
CONFIG_BUILD_LOG_DIR="$PWD/log"

# Disable unnecessary
CONFIG_IB=y
CONFIG_IB_CONFIG=y
CONFIG_NLS=n
CONFIG_KERNEL_BUILD_DOMAIN=""
CONFIG_HOSTNAME_BUILD=""
CONFIG_LOCALVERSION=""
